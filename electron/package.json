{
  "name": "starbound-desktop",
  "version": "1.0.0",
  "description": "Starbound rocket parts marketplace desktop app",
  "author": "Starbound",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:win": "electron-builder --win",
    "build:lin": "electron-builder --linux"
  },
  "build": {
    "appId": "com.starbound.desktop",
    "productName": "Starbound",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "portable"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "mime-types": "^3.0.2"
  }
}
